CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=
CUSTOM_TEMPERATURE=0.2
CUSTOM_MAX_TOKENS=1800

DEFAULT_AI_PROVIDER=openai
DEFAULT_MODEL_PROFILE=auto
API_CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

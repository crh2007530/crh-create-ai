OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# OpenAI-compatible custom provider:
# Works with OpenRouter, SiliconFlow, OneAPI, NewAPI, Volcengine Ark,
# Alibaba Bailian OpenAI-compatible endpoints, and similar gateways.
